{
	"name": "penguin-rich-presence",
	"description": "Show workspace status in your discord client",
	"publisher": "BoringPenguin",
	"version": "0.0.2",
	"engines": {
		"vscode": "^1.105.0"
	},
	"repository": {
		"url": "https://github.com/l0wkn1ght/PenguinRpc"
	},
	"keywords": [
		"presence",
		"status",
		"rich-presence",
		"chat"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "bun run package",
		"compile": "bun run check-types && bun run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "bun run check-types && bun run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "bun run compile-tests && bun run compile && bun run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test",
		"build": "tsc -p ./",
		"watch:transpiler": "tsc -w"
	},
	"dependencies": {
		"@types/jest": "^30.0.0",
		"discord-rpc": "4.0.1"
	},
	"contributes": {
		"configuration": {
			"title": "Penguin Discord RPC (Private Socket)",
			"properties": {
				"discordRpc.socketPath": {
					"type": "string",
					"default": "",
					"description": "Optional socket path (leave empty to use OS default under extension storage)."
				},
				"discordRpc.allowedOrigins": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Optional list of allowed local origins for incoming socket connections (for token-less use)."
				},
				"discordRpc.showLineAndErrors": {
					"type": "boolean",
					"default": true,
					"description": "Show sanitized line and error count in presence."
				}
			}
		},
		"commands": [
			{
				"command": "penguinRpc.start",
				"title": "Start Penguin RPC"
			},
			{
				"command": "penguinRpc.stop",
				"title": "Stop Penguin RPC"
			}
		]
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/discord-rpc": "^4.0.9",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@types/vscode": "^1.105.0",
		"@typescript-eslint/eslint-plugin": "^8.46.1",
		"@typescript-eslint/parser": "^8.46.1",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.25.11",
		"eslint": "^9.37.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3"
	},
	"license": "MIT",
	"private": false,
	"trustedDependencies": [
		"esbuild"
	]
}